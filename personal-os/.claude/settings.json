{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/workflow-guard.sh",
            "timeout": 10,
            "statusMessage": "Workflow risk guard..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/review-before-push.sh",
            "if": "Bash(git push*)",
            "timeout": 10,
            "statusMessage": "Pre-push review gate..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/review-before-push.sh",
            "if": "Bash(gh pr create*)",
            "timeout": 10,
            "statusMessage": "Pre-PR review gate..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/wireframe-gate.sh",
            "timeout": 10,
            "statusMessage": "Source-of-truth build gate..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/workflow-guard.sh",
            "timeout": 10,
            "statusMessage": "Workflow risk guard..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/format-on-edit.sh",
            "timeout": 15,
            "statusMessage": "Formatting edited file..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/simplify-on-stop.sh",
            "timeout": 5,
            "statusMessage": "Simplicity check..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/qa-on-stop.sh",
            "timeout": 15,
            "statusMessage": "Optional QA check..."
          }
        ]
      }
    ]
  }
}
